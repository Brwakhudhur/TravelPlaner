# Server Configuration
PORT=5001
NODE_ENV=development

# Database
# Local dev can use SQLite by leaving DATABASE_URL empty.
# Production on Render should use your Neon connection string.
DATABASE_URL=

# JWT Secret (Change this in production!)
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:3000

# AI Recommendations
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MAX_TOKENS=4000

# Default admin seeding (change for production)
ADMIN_EMAIL=brwa_as@hotmail.com
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=Administrator

ADMIN2_EMAIL=brwa_as@yahoo.com
ADMIN2_PASSWORD=
ADMIN2_DISPLAY_NAME=Administrator 2

# ===== EXTERNAL PROVIDER CONFIGURATION =====

# Redis (Optional) - For caching hot data
# Leave empty to use database-backed cache only
# REDIS_URL=redis://localhost:6379

# Nominatim Geocoding Service (Free, no key required)
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# Rate limit: 1 request/second
# Cache TTL: 24 hours

# Open-Meteo Weather Service (Free, no key required)
# OPENMETEO_BASE_URL=https://api.open-meteo.com/v1
# Rate limit: 10,000 free requests/day
# Cache TTL: 1 hour

# Visual Crossing Weather (Forecast)
# Get API key from: https://www.visualcrossing.com/weather-api
VISUAL_CROSSING_API_KEY=your-visual-crossing-api-key-here
# VISUAL_CROSSING_BASE_URL=https://weather.visualcrossing.com/VisualCrossingWebServices/rest/services

# OpenTripMap Points of Interest
# Get free API key from: https://opentripmap.io
OPENTRIPMAP_API_KEY=
# OPENTRIPMAP_BASE_URL=https://api.opentripmap.io/0.3
# Cache TTL: 7 days

# Image Providers (All optional, tries in order)
# Flickr - Get free API key from: https://www.flickr.com/services/api/misc.api_keys.html


# Pixabay - Get free API key from: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# Unsplash - Get free API key from: https://unsplash.com/developers
UNSPLASH_API_KEY=

# Pexels - Get free API key from: https://www.pexels.com/api/
PEXELS_API_KEY=

# Amadeus Flight Offers
# Get credentials from: https://developers.amadeus.com/
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
# AMADEUS_BASE_URL=https://test.api.amadeus.com

# Fallback image URL (used if no provider images found)
# DEFAULT_IMAGE_URL=https://via.placeholder.com/800x600?text=Travel+Destination

# Cache Configuration
# CACHE_TTL_GEOCODING=86400      # 24 hours
# CACHE_TTL_WEATHER=3600         # 1 hour
# CACHE_TTL_POI=604800           # 7 days
